# Variáveis de ambiente do backend.
# Em desenvolvimento (local), o .env atual já tem valores que funcionam.
# Em produção, defina todas estas no painel do Render/Railway:

# Banco de dados. Local: SQLite (deixe em branco). Produção: cole a URL do Postgres.
# DATABASE_URL=postgresql://usuario:senha@host:5432/profit_hub

# Chave JWT (gere uma forte para produção: openssl rand -hex 32)
SECRET_KEY=troque-em-producao-com-uma-string-longa-e-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — em produção, coloque a URL do frontend (Vercel). Exemplo:
# CORS_ORIGINS=https://profit-hub.vercel.app
CORS_ORIGINS=*
